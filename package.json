{
  "name": "@freqkflag/ai-os",
  "version": "0.1.0",
  "description": "Personal AI Operating System SDK with markdown memory, hybrid retrieval, reflection, prediction, E-Lang vectors, multi-agent cognition, and MCP server runtime.",
  "type": "module",
  "main": "dist/sdk/index.js",
  "exports": {
    ".": "./dist/sdk/index.js",
    "./mcp": "./dist/mcp/server.js"
  },
  "bin": {
    "ai-os": "./dist/cli/start.js",
    "pam": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/mcp/server.js",
    "start:http": "node dist/server/httpServer.js",
    "test": "vitest run",
    "postinstall": "node dist/installer/installMCP.js"
  },
  "keywords": [
    "personal-ai",
    "memory",
    "reflection",
    "prediction",
    "elang",
    "mcp",
    "sdk"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@modelcontextprotocol/inspector": "^0.21.1",
    "@types/node": "^22.10.2",
    "typescript": "^5.7.0",
    "vitest": "^2.0.5"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
