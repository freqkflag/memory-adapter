{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/freqkflag/e-lang/schemas/elang_state.schema.json",
  "title": "E-Lang State Vector Schema",
  "description": "Canonical JSON representation of an E-Lang state vector. This schema defines the key-value serialization form equivalent to the canonical ordered vector syntax E{V,A,C,S,K,D,B,N}.",
  "type": "object",
  "properties": {
    "V": {
      "type": "number",
      "description": "Valence axis value",
      "minimum": -1.0,
      "maximum": 1.0
    },
    "A": {
      "type": "number",
      "description": "Arousal axis value",
      "minimum": -1.0,
      "maximum": 1.0
    },
    "C": {
      "type": "number",
      "description": "Agency axis value (Control is a legacy alias)",
      "minimum": -1.0,
      "maximum": 1.0
    },
    "S": {
      "type": "number",
      "description": "Safety axis value",
      "minimum": -1.0,
      "maximum": 1.0
    },
    "K": {
      "type": "number",
      "description": "Certainty axis value",
      "minimum": -1.0,
      "maximum": 1.0
    },
    "D": {
      "type": "number",
      "description": "Dominance axis value",
      "minimum": -1.0,
      "maximum": 1.0
    },
    "B": {
      "type": "number",
      "description": "Attachment axis value",
      "minimum": -1.0,
      "maximum": 1.0
    },
    "N": {
      "type": "number",
      "description": "Novelty axis value",
      "minimum": -1.0,
      "maximum": 1.0
    }
  },
  "patternProperties": {
    "^x_": {
      "description": "Namespaced extension keys. Keys starting with 'x_' are reserved for extensions and should be ignored by implementations that do not recognize them.",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "examples": [
    {
      "description": "Valid: Complete state with all axes",
      "value": {
        "V": -0.4,
        "A": 0.7,
        "C": -0.2,
        "S": -0.6,
        "K": -0.1,
        "D": -0.3,
        "B": 0.8,
        "N": 0.2
      }
    },
    {
      "description": "Valid: Partial state (missing keys default to 0.0)",
      "value": {
        "V": 0.5,
        "A": 0.3
      }
    },
    {
      "description": "Valid: Boundary values at -1.0 and +1.0",
      "value": {
        "V": -1.0,
        "A": 1.0,
        "C": 0.0,
        "S": 0.0,
        "K": 0.0,
        "D": 0.0,
        "B": 0.0,
        "N": 0.0
      }
    },
    {
      "description": "Valid: State with namespaced extension",
      "value": {
        "V": 0.0,
        "A": 0.0,
        "C": 0.0,
        "S": 0.0,
        "K": 0.0,
        "D": 0.0,
        "B": 0.0,
        "N": 0.0,
        "x_custom": {
          "note": "Extension data"
        }
      }
    }
  ],
  "invalidExamples": [
    {
      "description": "Invalid: Value out of range (above 1.0)",
      "value": {
        "V": 1.5,
        "A": 0.0,
        "C": 0.0,
        "S": 0.0,
        "K": 0.0,
        "D": 0.0,
        "B": 0.0,
        "N": 0.0
      }
    },
    {
      "description": "Invalid: Value out of range (below -1.0)",
      "value": {
        "V": -1.5,
        "A": 0.0,
        "C": 0.0,
        "S": 0.0,
        "K": 0.0,
        "D": 0.0,
        "B": 0.0,
        "N": 0.0
      }
    },
    {
      "description": "Invalid: Non-namespaced extra key",
      "value": {
        "V": 0.0,
        "A": 0.0,
        "C": 0.0,
        "S": 0.0,
        "K": 0.0,
        "D": 0.0,
        "B": 0.0,
        "N": 0.0,
        "invalid_key": 0.0
      }
    },
    {
      "description": "Invalid: Non-numeric value",
      "value": {
        "V": "not_a_number",
        "A": 0.0,
        "C": 0.0,
        "S": 0.0,
        "K": 0.0,
        "D": 0.0,
        "B": 0.0,
        "N": 0.0
      }
    }
  ],
  "notes": [
    "Key order is not significant in JSON (unlike canonical syntax where order is fixed).",
    "Missing keys default to 0.0 per ELANG_SPEC.md section 4.",
    "Extension keys must be namespaced with 'x_' prefix to avoid collisions.",
    "This schema enforces structure only; no semantic interpretation is implied."
  ]
}