[Unit]
Description=PAM HTTP tool bridge
After=network.target

[Service]
Type=simple

# Run as non-root user (created by scripts/vm-install.sh).
User=pam
Group=pam

WorkingDirectory=/opt/pam/app
EnvironmentFile=/etc/pam/pam.env

ExecStart=/usr/bin/node /opt/pam/app/dist/server/httpServer.js
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target

