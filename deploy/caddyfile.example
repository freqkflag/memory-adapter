pam.cultofjoey.com {
  # Forward bearer tokens (when PAM_AUTH_TOKEN is set on the VM).
  handle /health {
    reverse_proxy 127.0.0.1:3000 {
      header_up Authorization {http.authorization}
    }
  }

  handle /tools {
    reverse_proxy 127.0.0.1:3000 {
      header_up Authorization {http.authorization}
    }
  }

  handle /tool/* {
    reverse_proxy 127.0.0.1:3000 {
      header_up Authorization {http.authorization}
    }
  }
}

